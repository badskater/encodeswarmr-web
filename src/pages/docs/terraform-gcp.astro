      <tr><td>Filestore</td><td>1 TB Standard</td><td>~$200</td></tr>
      <tr><td>Egress / NAT</td><td>variable</td><td>~$20</td></tr>
      <tr><td><strong>Total</strong></td><td></td><td><strong>~$891/mo</strong></td></tr>
