      <tr><td><code>ha_lock_timeout</code></td><td><code>30s</code></td><td>Stale lock expiry timeout</td></tr>
      <tr><td><code>install_postgres</code></td><td><code>true</code></td><td>Install and configure PostgreSQL on the controller host</td></tr>
      <tr><td><code>install_haproxy</code></td><td><code>false</code></td><td>Install HAProxy in front of controller pair (HA mode)</td></tr>
