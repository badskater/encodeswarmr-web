  <!-- Quick Start Section -->
  <section id="quickstart" class="border-t border-surface-800 bg-surface-900/30 py-24">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold text-white sm:text-4xl">Quick Start</h2>
        <p class="mt-4 text-lg text-surface-200">
          Get up and running in minutes with Docker Compose.
        </p>
      </div>

      <div class="mx-auto mt-12 max-w-3xl space-y-8">
        <div class="flex gap-4">
          <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary-600 text-sm font-bold text-white">1</div>
          <div class="flex-1">
            <h3 class="font-semibold text-white">Build and start the stack</h3>
            <div class="mt-3 overflow-hidden rounded-lg border border-surface-700 bg-surface-900">
              <div class="border-b border-surface-700 px-4 py-2">
                <span class="text-xs text-surface-200">bash</span>
              </div>
              <pre class="overflow-x-auto p-4 font-mono text-sm text-surface-200"><code># Build everything
make all

# Start Controller + PostgreSQL
cd deployments && docker compose up -d

# Apply database migrations
DATABASE_URL="postgres://distenc:&lt;pass&gt;@localhost:5432/encodeswarmr?sslmode=disable" \
  make migrate-up</code></pre>
            </div>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary-600 text-sm font-bold text-white">2</div>
          <div class="flex-1">
            <h3 class="font-semibold text-white">Complete the setup wizard</h3>
            <p class="mt-2 text-sm text-surface-200">
              Open <code class="rounded bg-surface-800 px-1.5 py-0.5 text-xs">http://localhost:8080</code> in your browser. The setup wizard guides you through creating your admin account, configuring storage paths, and generating your first agent enrollment token.
            </p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary-600 text-sm font-bold text-white">3</div>
          <div class="flex-1">
            <h3 class="font-semibold text-white">Install agents on encoding machines</h3>
            <div class="mt-3 overflow-hidden rounded-lg border border-surface-700 bg-surface-900">
              <div class="border-b border-surface-700 px-4 py-2">
                <span class="text-xs text-surface-200">Windows (GUI) / Linux (bash)</span>
              </div>
              <pre class="overflow-x-auto p-4 font-mono text-sm text-surface-200"><code># Windows — download the GUI installer from GitHub Releases
# encodeswarmr-agent-setup.exe

# Linux
sudo CONTROLLER_ADDRESS=encoder.example.com:9443 \
  ./scripts/install-agent-linux.sh

# Approve the agent
controller agent approve &lt;hostname&gt;</code></pre>
            </div>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary-600 text-sm font-bold text-white">4</div>
          <div class="flex-1">
            <h3 class="font-semibold text-white">Start encoding</h3>
            <p class="mt-2 text-sm text-surface-200">
              Register sources, create encoding presets, and queue jobs through the web UI or REST API. EncodeSwarmr handles distribution, monitoring, and concatenation automatically.
            </p>
          </div>
        </div>
      </div>

