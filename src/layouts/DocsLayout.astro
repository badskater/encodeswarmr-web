---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'EncodeSwarmr Documentation' } = Astro.props;

const sidebar = [
  { label: 'Overview', href: '/docs' },
  { label: 'Installation', href: '/docs/installation' },
  { label: 'Configuration', href: '/docs/configuration' },
  { label: 'Agents', href: '/docs/agents' },
  { label: 'API Reference', href: '/docs/api' },
  { label: 'HDR & Analysis', href: '/docs/hdr' },
  { label: 'Webhooks', href: '/docs/webhooks' },
  { label: 'High Availability', href: '/docs/ha' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/docs';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} - EncodeSwarmr Docs</title>
  </head>
  <body class="bg-surface-950 text-surface-200 antialiased">
    <!-- Nav -->
    <nav class="fixed top-0 left-0 right-0 z-50 border-b border-surface-800 bg-surface-950/80 backdrop-blur-xl">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
        <a href="/" class="flex items-center gap-3 text-xl font-bold text-white">
          <svg class="h-8 w-8" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="32" height="32" rx="8" fill="url(#lg)" />
            <path d="M8 16L14 10L20 16L14 22Z" fill="white" opacity="0.9" />
            <path d="M14 16L20 10L26 16L20 22Z" fill="white" opacity="0.6" />
            <defs><linearGradient id="lg" x1="0" y1="0" x2="32" y2="32"><stop stop-color="#3b82f6" /><stop offset="1" stop-color="#8b5cf6" /></linearGradient></defs>
          </svg>
          EncodeSwarmr
        </a>
        <div class="hidden items-center gap-8 md:flex">
          <a href="/#features" class="text-sm text-surface-200 transition-colors hover:text-white">Features</a>
          <a href="/docs" class="text-sm text-white font-medium">Docs</a>
          <a href="https://github.com/badskater/encodeswarmr" class="text-sm text-surface-200 transition-colors hover:text-white" target="_blank" rel="noopener">GitHub</a>
        </div>
        <button id="mobile-menu-btn" class="md:hidden text-surface-200 hover:text-white" aria-label="Toggle menu">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </nav>

    <div class="mx-auto flex max-w-7xl pt-20">
      <!-- Sidebar -->
      <aside class="hidden w-64 shrink-0 border-r border-surface-800 lg:block">
        <nav class="sticky top-20 p-6">
          <h3 class="mb-4 text-xs font-semibold uppercase tracking-wider text-surface-200">Documentation</h3>
          <ul class="space-y-1">
            {sidebar.map((item) => {
              const isActive = currentPath === item.href.replace(/\/$/, '');
              const cls = isActive
                ? 'block rounded-md px-3 py-2 text-sm transition-colors bg-primary-600/10 font-medium text-primary-400'
                : 'block rounded-md px-3 py-2 text-sm transition-colors text-surface-200 hover:bg-surface-800 hover:text-white';
              return (
                <li>
                  <a href={item.href} class={cls}>
                    {item.label}
                  </a>
                </li>
              );
            })}
          </ul>
        </nav>
      </aside>

      <!-- Content -->
      <main class="min-w-0 flex-1 px-6 py-8 lg:px-12 lg:py-10">
        <article class="prose-custom mx-auto max-w-3xl">
          <slot />
        </article>
      </main>
    </div>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      btn?.addEventListener('click', () => {
        const sidebar = document.querySelector('aside');
        sidebar?.classList.toggle('hidden');
        sidebar?.classList.toggle('fixed');
        sidebar?.classList.toggle('inset-0');
        sidebar?.classList.toggle('z-40');
        sidebar?.classList.toggle('bg-surface-950');
        sidebar?.classList.toggle('w-full');
        sidebar?.classList.toggle('pt-20');
      });
    </script>

    <style is:global>
      .prose-custom h1 {
        font-size: 2rem;
        font-weight: 700;
        color: white;
        margin-bottom: 1rem;
        line-height: 1.2;
      }
      .prose-custom h2 {
        font-size: 1.5rem;
        font-weight: 600;
        color: white;
        margin-top: 2.5rem;
        margin-bottom: 0.75rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--color-surface-800);
      }
      .prose-custom h3 {
        font-size: 1.125rem;
        font-weight: 600;
        color: white;
        margin-top: 1.5rem;
        margin-bottom: 0.5rem;
      }
      .prose-custom p {
        margin-bottom: 1rem;
        line-height: 1.75;
      }
      .prose-custom ul, .prose-custom ol {
        margin-bottom: 1rem;
        padding-left: 1.5rem;
      }
      .prose-custom li {
        margin-bottom: 0.25rem;
        line-height: 1.75;
      }
      .prose-custom ul li {
        list-style-type: disc;
      }
      .prose-custom ol li {
        list-style-type: decimal;
      }
      .prose-custom code {
        background: var(--color-surface-800);
        padding: 0.125rem 0.375rem;
        border-radius: 0.25rem;
        font-size: 0.875rem;
      }
      .prose-custom pre {
        background: var(--color-surface-900);
        border: 1px solid var(--color-surface-700);
        border-radius: 0.5rem;
        padding: 1rem;
        overflow-x: auto;
        margin-bottom: 1.5rem;
      }
      .prose-custom pre code {
        background: transparent;
        padding: 0;
        font-size: 0.875rem;
        line-height: 1.7;
      }
      .prose-custom a {
        color: var(--color-primary-400);
        text-decoration: none;
      }
      .prose-custom a:hover {
        color: var(--color-primary-300);
        text-decoration: underline;
      }
      .prose-custom table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 1.5rem;
      }
      .prose-custom th, .prose-custom td {
        border: 1px solid var(--color-surface-700);
        padding: 0.5rem 0.75rem;
        text-align: left;
        font-size: 0.875rem;
      }
      .prose-custom th {
        background: var(--color-surface-800);
        color: white;
        font-weight: 600;
      }
      .prose-custom blockquote {
        border-left: 3px solid var(--color-primary-500);
        padding-left: 1rem;
        margin-bottom: 1rem;
        color: var(--color-surface-200);
        font-style: italic;
      }
      .prose-custom .info-box {
        background: rgba(59, 130, 246, 0.05);
        border: 1px solid rgba(59, 130, 246, 0.2);
        border-radius: 0.5rem;
        padding: 1rem;
        margin-bottom: 1.5rem;
      }
    </style>
  </body>
</html>
